# Python bytecode
__pycache__/
*.py[cod]
*.py.class

# Environments
.env
.venv
env/
venv
ENV/
env.bak/
venv.bak/

# IDE-specific files
.vs/
.vscode/
.swp

# Private files
private/

# Build generated folders
.splat/
asm/
bin/
assets/
build/

# Object files
*.o

# Make dependency files
*.d

# N64 ROM files
*.z64
*.n64
*.v64

# M2C files
ctx.c
ctx_includes.c
*.ctx.c
debug_source.c

# Extracted assembly (generated)
asm_extracted/

# Permuter + execution-loop scratch dirs
nonmatchings/
permuter_settings.toml

# In-tree spot-check scratch (created and removed during the execution loop's finalize step)
src/*.c.spotcheck
build/src/*.spotcheck.o

# Sprint board (ephemeral live board + resume surface, written by /sprint-plan)
SPRINT.md

# Makefile options
.make_options

# Claude local settings
.claude/settings.local.json

# Swap
[._]*.s[a-v][a-z]
# comment out the next line if you don't need vector files
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Session
Session.vim
Sessionx.vim

# Temporary
.netrwhist
*~
# Auto-generated tag files
tags
# Persistent undo
[._]*.un~

# Ghidra scripts (local only)
ghidra/

# Local Claude Code MCP config (machine-specific Ghidra port pin)
.mcp.json

# S71 coddog cross-ref generated map (local, depends on ultralib/coddog builds)
tools/coddog/coddog_map.tsv
# nusys coddog cross-ref map (local, depends on the build/nusys-ref/ reference + coddog)
tools/coddog/nusys_map.tsv
# audio coddog cross-ref maps + version pin (local, depend on the build/audio-ref/ matrix + coddog).
# The scripts (tools/audio_*.sh, tools/audio_pin.py) and the manifest (tools/audio_ref_versions.tsv)
# stay tracked; only their generated output is ignored.
tools/coddog/audio/
tools/coddog/libmus_map.tsv
tools/coddog/libnaudio_map.tsv
tools/coddog/nuaulstl_map.tsv
tools/coddog/audio_pins.tsv

# Compiled-ucode build byproducts that build_audio_refs.sh (make coddog-sweep-audio)
# leaks into the repo root (e.g. n_csq.u); no .u file is tracked (S146).
*.u
